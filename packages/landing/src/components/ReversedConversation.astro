---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import VideoPlayer from './VideoPlayer.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<div class="reversed" id="concept">
  <div class="reversed-text">
    <h2>{t(lang, 'reversed.title')}</h2>
    <p>{t(lang, 'reversed.p1')}</p>
    <p>{t(lang, 'reversed.p2')}</p>
  </div>
  <div class="reversed-visual">
    <VideoPlayer src="/images/proposal-presence.mp4" id="proposal-video" />
  </div>
</div>

<style>
  .reversed {
    background: var(--text-primary);
    border-radius: 24px;
    padding: 80px 48px;
    margin: 0 32px;
    max-width: 1200px;
    margin-left: auto; margin-right: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .reversed-text h2 {
    font-size: 36px; font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
    margin-bottom: 20px;
  }
  .reversed-text p {
    font-size: 16px;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  @media (max-width: 900px) {
    .reversed { grid-template-columns: 1fr; padding: 48px 28px; margin: 0 16px; }
  }
  @media (max-width: 600px) {
    .reversed { padding: 36px 20px; }
  }
</style>
