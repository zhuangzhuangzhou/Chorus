---
import { t, tRaw } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import VideoPlayer from './VideoPlayer.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const showcaseItems = tRaw(lang, 'showcase.items') as Array<{ title: string; description: string }>;

const itemMeta = [
  { src: "/images/pixcel-workspace.mp4", type: "video", alt: "Pixel Workspace", wide: false },
  { src: "/images/kanban-presence.mp4", type: "video", alt: "Kanban Auto Update", wide: false },
  { src: "/images/kanban-dag.png", type: "image", alt: "Kanban & DAG", wide: false },
  { src: "/images/idea-elaborate.png", type: "image", alt: "Requirements Elaboration", wide: false },
  { src: "/images/proposal.png", type: "image", alt: "Proposal Review", wide: false },
  { src: "/images/task-ac.png", type: "image", alt: "Acceptance Criteria", wide: false },
];

const items = showcaseItems.map((item, i) => ({
  ...itemMeta[i],
  title: item.title,
  description: item.description,
}));
---

<section class="section" id="showcase">
  <div class="section-header">
    <div class="section-label">{t(lang, 'showcase.label')}</div>
    <h2>{t(lang, 'showcase.title')}</h2>
    <p>{t(lang, 'showcase.subtitle')}</p>
  </div>
  <div class="showcase-grid">
    {items.map((item, i) => (
      <div class:list={["showcase-item", { wide: item.wide }]}>
        {item.type === "video" ? (
          <div class="showcase-video-wrap">
            <VideoPlayer src={item.src} id={`showcase-${i}`} />
          </div>
        ) : (
          <img src={item.src} alt={item.alt} loading="lazy" class="showcase-img" data-lb-img={`img-${i}`} />
        )}
        <div class="showcase-caption">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Image lightbox -->
<div class="img-lightbox" id="img-lightbox">
  <button class="img-lb-close" id="img-lb-close" aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
  </button>
  <img class="img-lb-content" id="img-lb-content" src="" alt="" />
</div>

<script>
  const imgLb = document.getElementById('img-lightbox');
  const imgLbContent = document.getElementById('img-lb-content') as HTMLImageElement;
  const imgLbClose = document.getElementById('img-lb-close');

  document.querySelectorAll('.showcase-img').forEach(img => {
    img.addEventListener('click', () => {
      const src = (img as HTMLImageElement).src;
      const alt = (img as HTMLImageElement).alt;
      if (imgLbContent) { imgLbContent.src = src; imgLbContent.alt = alt; }
      imgLb?.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeImgLb() {
    imgLb?.classList.remove('open');
    document.body.style.overflow = '';
  }
  imgLbClose?.addEventListener('click', closeImgLb);
  imgLb?.addEventListener('click', (e) => { if (e.target === imgLb) closeImgLb(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeImgLb(); });
</script>

<style is:global>
  .img-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }
  .img-lightbox.open { opacity: 1; visibility: visible; }
  .img-lb-close {
    position: absolute;
    top: 20px; right: 20px;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }
  .img-lb-close:hover { background: rgba(255,255,255,0.2); }
  .img-lb-content {
    max-width: 90vw;
    max-height: 85vh;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    object-fit: contain;
  }
</style>

<style>
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .showcase-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.25s;
  }
  .showcase-item:hover {
    border-color: var(--primary-light);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.06);
  }
  .showcase-item.wide {
    grid-column: 1 / -1;
  }
  .showcase-item img {
    width: 100%;
    display: block;
    cursor: zoom-in;
  }
  .showcase-video-wrap {
    padding: 12px 12px 0;
  }
  .showcase-caption {
    padding: 16px 24px 20px;
  }
  .showcase-caption h3 {
    font-size: 16px; font-weight: 700;
    margin-bottom: 6px;
  }
  .showcase-caption p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .showcase-grid { grid-template-columns: 1fr; }
    .showcase-item.wide { grid-column: auto; }
  }
</style>
