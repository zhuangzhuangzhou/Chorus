                  "gap": 20,
                  "children": [
                    {
                      "type": "frame",
                      "id": "qIbFN",
                      "name": "Section 1",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "Fa38E",
                          "name": "section1Title",
                          "fill": "#2C2C2C",
                          "content": "1. Overview",
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "ImZVK",
                          "name": "section1Content",
                          "fill": "#6B6B6B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "This document outlines the product requirements for implementing user authentication functionality. The system will support multiple authentication methods including OAuth providers (Google, GitHub) and traditional email/password login.",
                          "lineHeight": 1.6,
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "VseSt",
                      "name": "Section 2",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "q1WfV",
                          "name": "section2Title",
                          "fill": "#2C2C2C",
                          "content": "2. User Stories",
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "GxfVo",
                          "name": "section2Content",
                          "fill": "#6B6B6B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "• As a user, I want to sign up with my email and password so that I can create an account\n• As a user, I want to sign in with Google/GitHub so that I don't need to remember another password\n• As a user, I want to reset my password if I forget it\n• As a user, I want to stay logged in across sessions",
                          "lineHeight": 1.6,
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "exfz8",
                      "name": "Section 3",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "6bPIX",
                          "name": "section3Title",
                          "fill": "#2C2C2C",
                          "content": "3. Functional Requirements",
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "XMyYb",
                          "name": "section3Content",
                          "fill": "#6B6B6B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "• FR-1: System shall support email/password registration with email verification\n• FR-2: System shall integrate with Google OAuth 2.0 for social login\n• FR-3: System shall integrate with GitHub OAuth for developer login\n• FR-4: System shall implement secure password reset via email token\n• FR-5: System shall support \"Remember Me\" functionality with refresh tokens",
                          "lineHeight": 1.6,
                          "fontFamily": "IBM Plex Sans",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
